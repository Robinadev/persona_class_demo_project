{
  "extends": "expo/tsconfig",
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/*"],
      "@components/*": ["app/components/*"],
      "@utils/*": ["app/utils/*"],
      "@types/*": ["app/types/*"],
      "@hooks/*": ["app/hooks/*"],
      "@store/*": ["app/store/*"]
    }
  }
}
