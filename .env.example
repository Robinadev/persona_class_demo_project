# Supabase Configuration
# Get these from your Supabase dashboard: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Application Settings
NEXT_PUBLIC_APP_NAME=Talaritel
NODE_ENV=development

# Admin Credentials (optional - for local testing)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Payment Gateway (optional - for Stripe integration)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email Configuration (optional - for notifications)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@talaritel.com

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# API Configuration
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=60000

# Feature Flags
NEXT_PUBLIC_ENABLE_DEMO_MODE=false
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false
